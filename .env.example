# Telegram (requerido)
TELEGRAM_BOT_TOKEN=tu_token_aqui
TELEGRAM_CHAT_ID=tu_chat_id_aqui

# PostgreSQL (requerido)
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/telemetria

# Identificador de esta máquina (default: hostname del sistema)
HOSTNAME=servidor

# Umbrales de alerta (°C y %)
ALERT_CPU_TEMP=75
ALERT_GPU_TEMP=80
ALERT_RAM_PCT=90
ALERT_VRAM_PCT=90

# Intervalo entre chequeos (minutos)
CHECK_INTERVAL_MIN=5

# GPU backend: nvidia, amd, intel (vacío = auto-detectar)
GPU_BACKEND=
